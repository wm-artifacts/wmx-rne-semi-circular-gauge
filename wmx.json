{
  "name": "rne-semi-circular-gauge",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboyina/rn-widgets/tree/0.0.0-dev/components/chart/gauge/semi-circular-gauge"
  },
  "homepage": "https://rn-charts.storybook.wavemaker.com/?path=/docs/charts-gauge-semi-circular-gauge--docs",
  "displayName": "Semi Circular Gauge",
  "description": "Semi-circular gauge chart with color-coded segments, customizable tick marks, and modern design",
  "iconUrl": "icon.svg",
  "component": "semi-circular-gauge.chart.tsx",
  "requires": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wavemaker/react-native-echarts": "1.0.0-dev.10"
  },
  "keywords": [
    "gauge",
    "chart",
    "semi-circular",
    "semicircle",
    "color-coded",
    "segments",
    "visualization",
    "metric",
    "indicator",
    "progress",
    "chart/gauge"
  ],
  "props": {
    "value": {
      "name": "value",
      "displayName": "Value",
      "description": "Current value to display. Example: 75",
      "type": "number",
      "isList": false,
      "isRequired": true
    },
    "min": {
      "name": "min",
      "displayName": "Min",
      "description": "Minimum value of the gauge scale. Example: 0",
      "type": "number",
      "isList": false,
      "defaultValue": 0,
      "isRequired": false
    },
    "max": {
      "name": "max",
      "displayName": "Max",
      "description": "Maximum value of the gauge scale. Example: 100",
      "type": "number",
      "isList": false,
      "defaultValue": 100,
      "isRequired": false
    },
    "width": {
      "name": "width",
      "displayName": "Width",
      "description": "Width of the chart in pixels. Example: 220",
      "type": "number",
      "isList": false,
      "defaultValue": 220,
      "isRequired": false
    },
    "height": {
      "name": "height",
      "displayName": "Height",
      "description": "Height of the chart in pixels. Example: 350",
      "type": "number",
      "isList": false,
      "defaultValue": 240,
      "isRequired": false
    },
    "theme": {
      "name": "theme",
      "displayName": "Theme",
      "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
      "type": "object",
      "isList": false,
      "isRequired": false
    },
    "colors": {
      "name": "colors",
      "displayName": "Colors",
      "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
      "type": "string",
      "isList": true,
      "isRequired": false
    }
  },
  "group": "chart/gauge",
  "webSupport": true
}
